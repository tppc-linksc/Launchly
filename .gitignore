.DS_Store

# Environment and local runtime
.env
.env.*
!.env.example
data/
logs/
tmp/

# Node / frontend
node_modules/
dist/
.vite/

# Build output (only specific dirs — do not use bare "target/" or it ignores com.launchly.target package)
services/api/target/

# Local binaries
cli/launchly

# IDE
.idea/
.vscode/

# Local development planning docs, not for upload
.claude/settings.local.json
.arts/
.pnpm-store/

# Generated / runtime
*.log
*.db
*.sqlite
coverage/
.nyc_output/
.claude/projects/

# Docs policy: only keep 3 baseline files in repo
docs/*
!docs/basic/
docs/basic/*
!docs/basic/UI与交互规范.md
!docs/basic/技术架构规范.md
!docs/basic/产品设计规范.md
